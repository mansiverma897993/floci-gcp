#!/usr/bin/env bash
# gcplocal — configure shell or run a command against the local floci-gcp emulator.
#
# Usage:
#   eval $(gcplocal env)           # export emulator env vars into current shell
#   eval $(gcplocal env --unset)   # unset them
#   gcplocal <any-gcloud-command>  # run gcloud with emulator endpoints

_ENDPOINT="${FLOCI_GCP_ENDPOINT:-http://localhost:4578}"
_HOST="${FLOCI_GCP_HOST:-localhost:4578}"
_PROJECT="${FLOCI_GCP_PROJECT:-floci-local}"

if [[ "${1:-}" == "env" ]]; then
    if [[ "${2:-}" == "--unset" ]]; then
        echo 'unset FLOCI_GCP_ENDPOINT'
        echo 'unset FLOCI_GCP_PROJECT'
        echo 'unset PUBSUB_EMULATOR_HOST'
        echo 'unset FIRESTORE_EMULATOR_HOST'
        echo 'unset DATASTORE_EMULATOR_HOST'
        echo 'unset STORAGE_EMULATOR_HOST'
        echo '# Run this command to unset floci-gcp env vars:'
        echo '# eval $(gcplocal env --unset)'
    else
        echo "export FLOCI_GCP_ENDPOINT=\"${_ENDPOINT}\""
        echo "export FLOCI_GCP_PROJECT=\"${_PROJECT}\""
        echo "export PUBSUB_EMULATOR_HOST=\"${_HOST}\""
        echo "export FIRESTORE_EMULATOR_HOST=\"${_HOST}\""
        echo "export DATASTORE_EMULATOR_HOST=\"${_HOST}\""
        echo "export STORAGE_EMULATOR_HOST=\"${_ENDPOINT}\""
        echo '# Run this command to configure your shell:'
        echo '# eval $(gcplocal env)'
    fi
    exit 0
fi

export PUBSUB_EMULATOR_HOST="${_HOST}"
export FIRESTORE_EMULATOR_HOST="${_HOST}"
export DATASTORE_EMULATOR_HOST="${_HOST}"
export STORAGE_EMULATOR_HOST="${_ENDPOINT}"
export CLOUDSDK_CORE_PROJECT="${_PROJECT}"

exec gcloud "$@"
